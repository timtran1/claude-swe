{
  "agent": {
    "planMode": true,
    "models": {
      "plan": "opus",
      "execute": "sonnet",
      "guard": "haiku"
    },
    "prompts": {
      "plan": "Additional instructions for planning mode",
      "execute": "Additional instructions for execute mode",
      "newTask": "Additional instructions for new tasks",
      "feedback": "Additional instructions for iterating on existing tasks"
    },
    "git": {
      "name": "Claude SWE",
      "email": "claude-swe@noreply.example.com"
    }
  },
  "trello": {
    "apiKey": "env.TRELLO_API_KEY",
    "apiSecret": "env.TRELLO_API_SECRET",
    "token": "env.TRELLO_TOKEN",
    "botUsername": "claude249",
    "boards": [
      {
        "name": "Claude SWE",
        "includeLists": ["Todo", "Doing", "Done", "Testing"],
        "doing": {
          "list": "Doing"
        },
        "done": {
          "list": "Done"
        },
        "repos": ["https://github.com/timtran1/claude-swe"]
      }
    ]
  },
  "slack": {
    "botToken": "env.SLACK_BOT_TOKEN",
    "appToken": "env.SLACK_APP_TOKEN",
    "signingSecret": "env.SLACK_SIGNING_SECRET",
    "channels": {
      "C0123ABCDEF": {
        "repos": ["https://github.com/myorg/my-app"]
      }
    }
  },
  "jira": {
    "host": "https://myorg.atlassian.net",
    "email": "bot@myorg.com",
    "apiToken": "env.JIRA_API_TOKEN",
    "webhookSecret": "env.JIRA_WEBHOOK_SECRET",
    "botAccountId": null,
    "doing": { "status": "In Progress" },
    "done": { "status": "Done" },
    "projects": [
      {
        "key": "MYPROJ",
        "includeStatuses": ["To Do", "Backlog"],
        "doing": { "status": "In Progress" },
        "done": { "status": "Done" },
        "repos": ["https://github.com/myorg/my-app"]
      }
    ]
  },
  "github": {
    "token": "env.GITHUB_TOKEN",
    "webhookSecret": "env.GITHUB_WEBHOOK_SECRET"
  },
  "anthropic": {
    "apiKey": "env.ANTHROPIC_API_KEY"
  },
  "server": {
    "port": 3000,
    "webhookBaseUrl": "https://claude-swe-dev.deepsel.com"
  },
  "redis": {
    "host": "redis.redis.svc.cluster.local",
    "port": 6379
  },
  "containers": {
    "backend": "kubernetes",
    "workerImage": "ghcr.io/timtran1/claude-swe-worker:latest",
    "concurrency": 10,
    "docker": {
      "enableSocketMount": true
    },
    "kubernetes": {
      "namespace": "claude-swe",
      "storageClass": "local-storage",
      "enableDinD": true
    }
  }
}