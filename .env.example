TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_WEBHOOK_SECRET=
TRELLO_DONE_LIST_ID=
TRELLO_BOARD_ID=

GITHUB_TOKEN=
ANTHROPIC_API_KEY=

# Public URL Trello will call for webhooks (use ngrok for local dev)
WEBHOOK_BASE_URL=https://your-server.example.com

# Redis connection (default works with docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379

# How long (ms) to let Claude Code run before timing out (default 30 min)
CLAUDE_TIMEOUT_MS=1800000

# Port for the webhook server
PORT=3000
