TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_WEBHOOK_SECRET=
TRELLO_DONE_LIST_ID=
TRELLO_BOARD_ID=
TRELLO_CLAUDE_USERNAME=claude

GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=

# Public URL for webhooks (use ngrok for local dev)
WEBHOOK_BASE_URL=https://your-server.example.com

# Docker worker image name (must be pre-built: docker compose build worker)
WORKER_IMAGE=claude-swe-worker:latest

# Fallback repo URL when the Trello card doesn't specify one
# DEFAULT_GITHUB_REPO=https://github.com/myorg/my-app

# Redis connection (defaults work with docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379

# Port for the webhook server
PORT=3000
