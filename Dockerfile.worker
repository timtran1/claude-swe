FROM node:20-slim

# Install system deps + build tools for native modules across languages
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ca-certificates \
    gnupg \
    build-essential \
    python3 \
    python3-pip \
    python3-venv \
    libssl-dev \
    pkg-config \
    unzip \
    gosu \
    && rm -rf /var/lib/apt/lists/*

# mise — universal runtime version manager
# Automatically reads .mise.toml / .tool-versions / .nvmrc / .python-version
# and installs the correct Node, Python, Go, Ruby, Rust, Java, etc.
# MISE_DATA_DIR is set to /opt/mise so installs are accessible to the worker user (not root-home-scoped)
ENV MISE_DATA_DIR=/opt/mise
RUN curl https://mise.run | sh
ENV PATH="/opt/mise/shims:/root/.local/bin:${PATH}"
RUN echo 'eval "$(/root/.local/bin/mise activate bash)"' >> /root/.bashrc \
    && mise settings set experimental true

# Pre-install common Node and Python versions so mise doesn't download them at runtime
RUN mise install node@18 node@20 node@22 python@3.11 python@3.12 python@3.13 \
    && chmod -R a+rX /opt/mise

# gh CLI — used by Claude to open PRs, check status, etc.
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Docker CLI + Compose plugin — workers use these to run `docker compose up`
# for test environments. The daemon comes from the host socket (Docker backend)
# or a DinD sidecar (Kubernetes backend).
RUN curl -fsSL https://download.docker.com/linux/debian/gpg \
    | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] \
       https://download.docker.com/linux/debian bookworm stable" \
    | tee /etc/apt/sources.list.d/docker.list > /dev/null \
    && apt-get update \
    && apt-get install -y docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Playwright MCP — pre-installed so npx uses the local copy without downloading at runtime
RUN npm install -g @playwright/mcp

# Install Playwright browsers to a shared path readable by all users (not /root/.cache which worker can't access)
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright
RUN $(npm root -g)/@playwright/mcp/node_modules/.bin/playwright install --with-deps chromium \
    && chmod -R 755 /opt/ms-playwright \
    && chmod a+w /opt/ms-playwright

# Trello MCP — pre-installed so npx uses local copy without downloading at runtime
RUN npm install -g @delorenj/mcp-server-trello

# Create a non-root user — claude --dangerously-skip-permissions refuses to run as root.
# The entrypoint runs as root for setup, then uses gosu to drop to this user for claude.
RUN useradd -m -u 1001 -s /bin/bash worker && mkdir -p /workspace

# Working directory for cloned repos — this path gets a persistent volume
WORKDIR /workspace

# The orchestrator sends the prompt via env var CLAUDE_PROMPT.
# The entrypoint: set up MCP config, then run claude.
COPY scripts/download-images.mjs /opt/mcp/download-images.mjs
COPY worker-logger.js /opt/mcp/worker-logger.js
COPY worker-entrypoint.sh /usr/local/bin/worker-entrypoint.sh
RUN chmod +x /usr/local/bin/worker-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/worker-entrypoint.sh"]
